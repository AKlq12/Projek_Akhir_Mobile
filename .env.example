# ===========================================
# FitPro - Environment Variables (Example)
# ===========================================
# Copy file ini menjadi .env dan isi dengan API keys milikmu
# cp .env.example .env
# ===========================================

# Supabase (Auth + Database)
# Dapatkan dari: https://supabase.com → Dashboard → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# wger.de API (Exercise Data)
# Dapatkan dari: https://wger.de/en/user/registration → Login → API page
WGER_API_KEY=your_wger_api_key_here
WGER_BASE_URL=https://wger.de/api/v2

# Google Gemini (AI/LLM)
# Dapatkan dari: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSy...

# ExchangeRate API (Currency Converter)
# Dapatkan dari: https://exchangerate-api.com → Sign Up (free tier)
EXCHANGE_RATE_API_KEY=your_exchange_rate_api_key_here
EXCHANGE_RATE_BASE_URL=https://v6.exchangerate-api.com/v6
